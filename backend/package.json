{
  "name": "vietnet-backend",
  "version": "0.1.0",
  "description": "VietNet Interior Backend API",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start:prod": "node dist/main",
    "lint": "eslint 'src/**/*.ts'",
    "type-check": "tsc --noEmit",
    "migration:run": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:run -d src/database/data-source.ts",
    "migration:run:prod": "node ./node_modules/typeorm/cli.js migration:run -d dist/database/data-source.js",
    "seed:admin": "ts-node -r tsconfig-paths/register src/scripts/seed-admin.ts",
    "seed:data": "ts-node -r tsconfig-paths/register src/scripts/seed-data.ts",
    "seed:admin:prod": "node dist/scripts/seed-admin.js",
    "seed:data:prod": "node dist/scripts/seed-data.js"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.1019.0",
    "@nestjs/bullmq": "^10.1.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/mapped-types": "^2.1.0",
    "@nestjs/passport": "^10.0.0",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^10.3.0",
    "@nestjs/throttler": "^5.1.0",
    "@nestjs/typeorm": "^10.0.0",
    "@nestjs/websockets": "^10.3.0",
    "@socket.io/redis-adapter": "^8.2.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^5.1.0",
    "bullmq": "^5.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.0",
    "isomorphic-dompurify": "^2.0.0",
    "mysql2": "^3.9.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.0",
    "pino": "^8.19.0",
    "pino-http": "^9.0.0",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.9.4",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.0",
    "typeorm": "^0.3.20",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bcrypt": "^5.0.0",
    "@types/cookie-parser": "^1.4.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.0.0",
    "@types/passport-jwt": "^4.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.0"
  }
}
