# NEVER commit real secrets. Copy to .env and fill.

# Server
PORT=4000
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=vietnet
DB_PASSWORD=<CHANGE_ME_MYSQL_APP_PASSWORD>
DB_NAME=vietnet

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT — MUST be >=32 chars. Generate: openssl rand -base64 32
# Placeholder "generate-with-..." bi reject boi env.validation.ts — phai doi gia tri that
JWT_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_PRIVATE=vietnet-private
R2_BUCKET_PUBLIC=vietnet-public
R2_PUBLIC_URL=

# Resend Email
RESEND_API_KEY=
MAIL_FROM=VietNet Interior <noreply@bhquan.site>
ADMIN_EMAIL=admin@bhquan.site

# Cron — secret header de protect /api/cron/* endpoints
CRON_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>

# CORS
ALLOWED_ORIGINS=http://localhost:3000

# Frontend URL (dung cho link password reset trong email)
FRONTEND_URL=http://localhost:3000

# Logging
LOG_LEVEL=debug
