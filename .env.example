# ──────────────────────────────────────────
# Docker Compose root environment variables
# Copy this file to .env and fill in values
# ──────────────────────────────────────────

# ── MySQL ────────────────────────────────
# CHANGE THESE! Generate strong passwords: `openssl rand -base64 32`
MYSQL_ROOT_PASSWORD=<CHANGE_ME_MYSQL_ROOT_PASSWORD>
MYSQL_PASSWORD=<CHANGE_ME_MYSQL_APP_PASSWORD>

# ── Backend (.env in /backend/) ──────────
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=vietnet
DB_PASSWORD=<CHANGE_ME_MYSQL_APP_PASSWORD>
DB_NAME=vietnet

REDIS_HOST=redis
REDIS_PORT=6379

# JWT_SECRET MUST be >=32 chars. Generate: `openssl rand -base64 32`
JWT_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>
JWT_EXPIRATION=3600
REFRESH_TOKEN_EXPIRATION=604800

# Cloudflare R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_PRIVATE=vietnet-private
R2_BUCKET_PUBLIC=vietnet-public
R2_PUBLIC_URL=https://pub-vietnet.r2.dev

# Mail (Resend)
RESEND_API_KEY=
ADMIN_EMAIL=admin@bhquan.site

# ISR Revalidation — generate with: openssl rand -base64 32
REVALIDATE_SECRET=<CHANGE_ME_GENERATE_WITH_openssl_rand_base64_32>
NEXT_REVALIDATE_URL=http://frontend:3000

# ── Frontend (.env in /frontend/) ────────
NEXT_PUBLIC_API_URL=https://bhquan.store/api
NEXT_PUBLIC_SITE_URL=https://bhquan.store

# ── Dev Ports (tránh xung đột với WebPhoto) ─
# Frontend: 3100 (thay vì 3000)
# Backend:  4100 (thay vì 4000)
# MySQL:    3307 (thay vì 3306)
# Redis:    6380 (thay vì 6379)
# Nginx:    8080/8443 (thay vì 80/443)

# ── Backup ───────────────────────────────
MYSQL_BACKUP_PASSWORD=<CHANGE_ME_MYSQL_APP_PASSWORD>

# ── Google Drive Backup (optional) ───────
# Service Account authentication — see scripts/.gdrive-credentials.example.json
GDRIVE_ENABLED=false
GDRIVE_CREDENTIALS_PATH=./scripts/.gdrive-credentials.json
GDRIVE_FOLDER_ID=
GDRIVE_DB_SUBFOLDER=database
GDRIVE_UPLOADS_SUBFOLDER=media
# Giu N ban moi nhat trong moi subfolder, xoa cu hon
GDRIVE_KEEP_COUNT=14
# Thu muc chua .sql.gz do backup-mysql.sh tao ra
BACKUP_DIR=/opt/vietnet/backups
# Thu muc uploads cua backend (zip truoc khi upload)
UPLOADS_DIR=./backend/uploads
